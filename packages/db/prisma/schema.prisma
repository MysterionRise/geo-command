generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Plan {
  FREE
  STARTER
  PROFESSIONAL
  AGENCY
  ENTERPRISE
}

enum Role {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

model Organisation {
  id               String       @id @default(cuid())
  name             String
  slug             String       @unique
  plan             Plan         @default(FREE)
  stripeCustomerId String?      @unique
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  users            User[]
  workspaces       Workspace[]
  invitations      Invitation[]
}

model User {
  id        String       @id @default(cuid())
  clerkId   String       @unique
  email     String       @unique
  name      String?
  role      Role         @default(MEMBER)
  orgId     String
  org       Organisation @relation(fields: [orgId], references: [id], onDelete: Cascade)
  createdAt DateTime     @default(now())

  @@index([orgId])
  @@index([clerkId])
}

model Workspace {
  id        String       @id @default(cuid())
  name      String
  slug      String
  orgId     String
  org       Organisation @relation(fields: [orgId], references: [id], onDelete: Cascade)
  createdAt DateTime     @default(now())
  projects  Project[]

  @@unique([orgId, slug])
  @@index([orgId])
}

model Invitation {
  id         String       @id @default(cuid())
  email      String
  role       Role         @default(MEMBER)
  orgId      String
  org        Organisation @relation(fields: [orgId], references: [id], onDelete: Cascade)
  token      String       @unique @default(cuid())
  expiresAt  DateTime
  acceptedAt DateTime?
  createdAt  DateTime     @default(now())

  @@index([orgId])
  @@index([token])
  @@index([email, orgId])
}

enum PromptStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

model AIEngine {
  id        String   @id @default(cuid())
  provider  String
  model     String
  label     String
  isDefault Boolean  @default(false)
  maxTokens Int      @default(4096)
  createdAt DateTime @default(now())

  projects  Project[]
}

model Project {
  id             String         @id @default(cuid())
  name           String
  slug           String
  description    String?
  brandVoice     String?
  targetAudience String?
  keywords       String[]
  language       String         @default("en")
  workspaceId    String
  workspace      Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  engineId       String?
  engine         AIEngine?      @relation(fields: [engineId], references: [id], onDelete: SetNull)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  prompts        Prompt[]
  clusters       PromptCluster[]

  @@unique([workspaceId, slug])
  @@index([workspaceId])
}

model Prompt {
  id        String        @id @default(cuid())
  text      String
  status    PromptStatus  @default(DRAFT)
  source    String        @default("manual")
  embedding Float[]
  projectId String
  project   Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  clusterId String?
  cluster   PromptCluster? @relation(fields: [clusterId], references: [id], onDelete: SetNull)
  createdAt DateTime      @default(now())

  @@index([projectId])
  @@index([clusterId])
}

model PromptCluster {
  id        String   @id @default(cuid())
  label     String
  centroid  Float[]
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  prompts   Prompt[]

  @@index([projectId])
}
