{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "DATABASE_URL",
    "CLERK_SECRET_KEY",
    "CLERK_PUBLISHABLE_KEY",
    "NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY",
    "NEXT_PUBLIC_CLERK_SIGN_IN_URL",
    "NEXT_PUBLIC_CLERK_SIGN_UP_URL",
    "UPSTASH_REDIS_REST_URL",
    "UPSTASH_REDIS_REST_TOKEN",
    "ANTHROPIC_API_KEY",
    "OPENAI_API_KEY",
    "REDIS_URL"
  ],
  "tasks": {
    "db:generate": {
      "cache": false
    },
    "db:migrate": {
      "cache": false
    },
    "build": {
      "dependsOn": [
        "^build",
        "^db:generate"
      ],
      "outputs": [
        "dist/**",
        ".next/**",
        "!.next/cache/**"
      ]
    },
    "dev": {
      "dependsOn": [
        "^db:generate"
      ],
      "persistent": true,
      "cache": false
    },
    "lint": {
      "dependsOn": [
        "^db:generate"
      ]
    },
    "test": {
      "dependsOn": [
        "^db:generate"
      ]
    },
    "test:e2e": {
      "dependsOn": [
        "^db:generate"
      ]
    }
  }
}
